{
  "expo": {
    "name": "IronLog",
    "slug": "ironlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ironlog",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "IronLog använder kameran för att fotografera maskiner och vikter.",
        "NSPhotoLibraryUsageDescription": "IronLog läser bilder från ditt bibliotek."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b0d13",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-camera"
    ]
  }
}
